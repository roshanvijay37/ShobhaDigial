---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import Reveal from '../components/Reveal.astro';
import Icon from '../components/Icon.astro';
import { site, whatsappUrl, telUrl, mapsUrl } from '../data/site';

const mapEmbed = `https://www.google.com/maps?q=${encodeURIComponent(site.mapQuery)}&output=embed`;
const contactItems = [
  { icon: 'whatsapp', label: 'WhatsApp', value: site.phoneDisplay, href: whatsappUrl(), external: true },
  { icon: 'phone', label: 'Call us', value: site.phoneDisplay, href: telUrl(), external: false },
  { icon: 'map-pin', label: 'Visit', value: `${site.address.line1}, ${site.address.line2}`, href: mapsUrl(), external: true },
  { icon: 'clock', label: 'Hours', value: site.hours, href: '', external: false },
];
---
<BaseLayout
  title="Contact"
  description="Get in touch with Shobha Digital Studio, Belvai — WhatsApp, call or send an enquiry for weddings, events, kids and temple photography."
>
  <section class="bg-maroon py-16 text-center sm:py-20">
    <div class="shell">
      <p class="font-kannada text-base text-gold-light">ಸಂಪರ್ಕಿಸಿ</p>
      <h1 class="mt-3 font-serif text-5xl font-semibold text-cream sm:text-6xl">Get in Touch</h1>
      <div class="divider mx-auto mt-5 max-w-xs text-gold" aria-hidden="true">◆</div>
      <p class="mx-auto mt-5 max-w-2xl text-cream/80">
        We'd love to hear about your occasion. Reach us on WhatsApp for the quickest reply, or send
        an enquiry below.
      </p>
    </div>
  </section>

  <section class="bg-cream py-16 sm:py-24">
    <div class="shell grid gap-12 lg:grid-cols-2">
      <Reveal>
        <h2 class="font-serif text-3xl text-ink">Reach us directly</h2>
        <span class="mt-4 block h-px w-16 bg-gold"></span>
        <div class="mt-8 space-y-4">
          {contactItems.map((item) => {
            const inner = (
              <div class="flex items-center gap-4 rounded-xl border border-maroon/10 bg-white/50 p-5 transition-colors hover:border-gold/50">
                <span class="grid h-12 w-12 shrink-0 place-items-center rounded-full bg-maroon text-gold">
                  <Icon name={item.icon} size={22} />
                </span>
                <span>
                  <span class="block text-xs font-semibold uppercase tracking-[0.18em] text-muted">{item.label}</span>
                  <span class="mt-0.5 block font-serif text-lg text-ink">{item.value}</span>
                </span>
              </div>
            );
            return item.href ? (
              <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined} class="block">{inner}</a>
            ) : (
              <div>{inner}</div>
            );
          })}
        </div>

        <div class="mt-6 flex items-center gap-3">
          <a href={site.social.instagram} target="_blank" rel="noopener" class="grid h-11 w-11 place-items-center rounded-full border border-maroon/20 text-maroon transition-colors hover:border-gold hover:text-gold" aria-label="Instagram">
            <Icon name="instagram" size={20} />
          </a>
          <a href={site.social.facebook} target="_blank" rel="noopener" class="grid h-11 w-11 place-items-center rounded-full border border-maroon/20 text-maroon transition-colors hover:border-gold hover:text-gold" aria-label="Facebook">
            <Icon name="facebook" size={20} />
          </a>
        </div>

        <div class="mt-8 overflow-hidden rounded-xl border border-maroon/10">
          <iframe
            src={mapEmbed}
            title="Map to Shobha Digital Studio, Belvai"
            class="h-64 w-full"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </Reveal>

      <Reveal delay={120}>
        <h2 class="font-serif text-3xl text-ink">Send an enquiry</h2>
        <span class="mt-4 block h-px w-16 bg-gold"></span>
        <div class="mt-8">
          <ContactForm />
        </div>
      </Reveal>
    </div>
  </section>
</BaseLayout>
