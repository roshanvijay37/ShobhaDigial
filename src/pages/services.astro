---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Reveal from '../components/Reveal.astro';
import Icon from '../components/Icon.astro';
import { href } from '../lib/url';
import { whatsappUrl } from '../data/site';
import { services } from '../data/services';

const process = [
  { step: '01', title: 'Enquire', text: 'Tell us your occasion, date and what you have in mind — on WhatsApp or the form.' },
  { step: '02', title: 'Plan', text: 'We discuss coverage, style and a package that suits your budget.' },
  { step: '03', title: 'Capture', text: 'On the day, we work calmly and unobtrusively to capture every moment.' },
  { step: '04', title: 'Deliver', text: 'Edited photos, films and a designed album — printed and digital.' },
];
---
<BaseLayout
  title="Services"
  description="Wedding & pre-wedding photography and films, kids & newborn, temple and Yakshagana coverage, portraits, events, album design and printing — Shobha Digital Studio, Belvai."
>
  <section class="bg-maroon-dark py-16 text-center sm:py-20">
    <div class="shell">
      <p class="font-kannada text-base text-gold-light">ನಮ್ಮ ಸೇವೆಗಳು</p>
      <h1 class="mt-3 font-serif text-5xl font-semibold text-cream sm:text-6xl">Services</h1>
      <div class="divider mx-auto mt-5 max-w-xs text-gold" aria-hidden="true">◆</div>
      <p class="mx-auto mt-5 max-w-2xl text-cream/80">
        One studio for every celebration — from the grandest wedding to the quietest newborn shoot.
      </p>
    </div>
  </section>

  <section class="bg-cream py-16 sm:py-24">
    <div class="shell">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((service, i) => (
          <Reveal delay={(i % 4) * 80}><ServiceCard service={service} /></Reveal>
        ))}
      </div>
      <p class="mx-auto mt-12 max-w-2xl text-center text-muted">
        Every package is tailored to your occasion and budget. Tell us what you need and we will put
        together the right coverage for you.
      </p>
    </div>
  </section>

  <section class="bg-cream-2 py-16 sm:py-24">
    <div class="shell">
      <Reveal><SectionHeading eyebrow="How it works" title="A simple, calm process" /></Reveal>
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {process.map((p, i) => (
          <Reveal delay={i * 80}>
            <div class="h-full rounded-xl border border-maroon/10 bg-white/50 p-7">
              <div class="font-serif text-5xl text-maroon">{p.step}</div>
              <h3 class="mt-3 font-serif text-2xl text-ink">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{p.text}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-maroon py-16">
    <div class="shell text-center">
      <Reveal>
        <h2 class="mx-auto max-w-2xl font-serif text-4xl text-cream sm:text-5xl">Tell us about your occasion</h2>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn btn-gold">
            <Icon name="whatsapp" size={16} /> Get a quote on WhatsApp
          </a>
          <a href={href('/contact')} class="btn btn-ghost-light">Contact Us</a>
        </div>
      </Reveal>
    </div>
  </section>
</BaseLayout>
