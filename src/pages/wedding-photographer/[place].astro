---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Gallery from '../../components/Gallery.astro';
import Reveal from '../../components/Reveal.astro';
import Icon from '../../components/Icon.astro';
import { href } from '../../lib/url';
import { site, whatsappUrl } from '../../data/site';
import { services } from '../../data/services';
import { areas } from '../../data/areas';
import { portfolio } from '../../data/portfolio';

export function getStaticPaths() {
  return areas.map((area) => ({ params: { place: area.slug }, props: { area } }));
}

const { area } = Astro.props;
const others = areas.filter((a) => a.slug !== area.slug);
const featured = portfolio.filter((p) => p.featured).slice(0, 4);
const title = `Wedding Photographer in ${area.place}`;
const description = `Shobha Digital Studio — wedding, pre-wedding, kids, temple & Yakshagana photography and cinematography serving ${area.place} and all of Dakshina Kannada, from Belvai.`;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Wedding & event photography and cinematography',
  provider: {
    '@type': 'PhotographyBusiness',
    name: site.name,
    telephone: `+${site.phone}`,
    areaServed: `${area.place}, Karnataka`,
  },
  areaServed: { '@type': 'City', name: area.place },
  url: new URL(href(`/wedding-photographer/${area.slug}`), Astro.site).href,
};
---
<BaseLayout title={title} description={description}>
  <section class="bg-cream-2 py-16 text-center sm:py-20">
    <div class="shell">
      <p class="font-kannada text-base text-gold">{area.place}</p>
      <h1 class="mt-3 font-serif text-4xl font-semibold text-ink sm:text-6xl">
        Wedding Photographer in {area.place}
      </h1>
      <div class="divider mx-auto mt-5 max-w-xs text-gold" aria-hidden="true">◆</div>
      <p class="mx-auto mt-5 max-w-2xl text-ink/70">
        Photography &amp; cinematography from Belvai, for {area.place} and all of Dakshina Kannada.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href={whatsappUrl(`Hello Shobha Digital Studio, I'm enquiring about photography in ${area.place}.`)} target="_blank" rel="noopener" class="btn btn-gold">
          <Icon name="whatsapp" size={16} /> Check availability
        </a>
        <a href={href('/portfolio')} class="btn btn-outline">View Portfolio</a>
      </div>
    </div>
  </section>

  <section class="bg-cream py-16 sm:py-24">
    <div class="shell grid items-center gap-10 lg:grid-cols-2">
      <Reveal>
        <span class="eyebrow text-maroon">Serving {area.place}</span>
        <h2 class="mt-4 font-serif text-3xl text-ink sm:text-4xl">Your day, beautifully kept</h2>
        <span class="mt-5 block h-px w-16 bg-gold"></span>
        <p class="mt-6 leading-relaxed text-ink/80">{area.intro}</p>
        <p class="mt-4 leading-relaxed text-muted">
          Whether it's {area.local}, we bring a calm, candid eye and the craft of a full digital
          studio — photography, films, album design and printing, all under one roof.
        </p>
      </Reveal>
      <Reveal delay={120} class="block">
        <Gallery items={featured} />
      </Reveal>
    </div>
  </section>

  <section class="bg-cream-2 py-16 sm:py-24">
    <div class="shell">
      <Reveal><SectionHeading eyebrow="What we offer" title={`Services in ${area.place}`} /></Reveal>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {services.slice(0, 4).map((service, i) => (
          <Reveal delay={(i % 4) * 80}><ServiceCard service={service} /></Reveal>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href={href('/services')} class="btn btn-primary">All Services <Icon name="arrow-right" size={16} /></a>
      </div>
    </div>
  </section>

  <section class="bg-cream py-14">
    <div class="shell text-center">
      <h2 class="font-serif text-2xl text-ink">We also serve nearby</h2>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        {others.map((a) => (
          <a href={href(`/wedding-photographer/${a.slug}`)} class="rounded-full border border-maroon/20 px-5 py-2 text-sm font-medium text-maroon transition-colors hover:border-gold hover:bg-gold/10">
            {a.place}
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-cream-2 py-16">
    <div class="shell text-center">
      <Reveal>
        <h2 class="mx-auto max-w-2xl font-serif text-3xl text-ink sm:text-4xl">
          Planning something in {area.place}?
        </h2>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a href={whatsappUrl(`Hello Shobha Digital Studio, I'm enquiring about photography in ${area.place}.`)} target="_blank" rel="noopener" class="btn btn-gold">
            <Icon name="whatsapp" size={16} /> Enquire on WhatsApp
          </a>
          <a href={href('/contact')} class="btn btn-outline">Contact Us</a>
        </div>
      </Reveal>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} is:inline />
</BaseLayout>
