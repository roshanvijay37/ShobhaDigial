---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Gallery from '../components/Gallery.astro';
import FilmGrid from '../components/FilmGrid.astro';
import Reveal from '../components/Reveal.astro';
import { portfolio, films, categories } from '../data/portfolio';
---
<BaseLayout
  title="Portfolio"
  description="A gallery of weddings, temple festivals, Yakshagana, kids and portrait photography by Shobha Digital Studio, Belvai."
>
  <section class="bg-maroon py-16 text-center sm:py-20">
    <div class="shell">
      <p class="font-kannada text-base text-gold-light">ಚಿತ್ರ ಸಂಗ್ರಹ</p>
      <h1 class="mt-3 font-serif text-5xl font-semibold text-cream sm:text-6xl">Our Portfolio</h1>
      <div class="divider mx-auto mt-5 max-w-xs text-gold" aria-hidden="true">◆</div>
      <p class="mx-auto mt-5 max-w-2xl text-cream/80">
        A glimpse of the moments we have had the honour to capture across Belvai, Moodbidri and
        coastal Karnataka.
      </p>
    </div>
  </section>

  <section class="bg-cream py-16 sm:py-24">
    <div class="shell">
      <Gallery items={portfolio} filters={categories} />
    </div>
  </section>

  <section class="bg-maroon-dark py-16 sm:py-24">
    <div class="shell">
      <Reveal><SectionHeading eyebrow="On screen" title="Films & cinematography" tone="light" /></Reveal>
      <Reveal class="mt-12 block"><FilmGrid films={films} /></Reveal>
    </div>
  </section>
</BaseLayout>
