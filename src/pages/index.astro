---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Gallery from '../components/Gallery.astro';
import FilmGrid from '../components/FilmGrid.astro';
import Testimonial from '../components/Testimonial.astro';
import Reveal from '../components/Reveal.astro';
import Icon from '../components/Icon.astro';
import { href } from '../lib/url';
import { getImage } from '../lib/images';
import { site, whatsappUrl } from '../data/site';
import { services } from '../data/services';
import { portfolio, films } from '../data/portfolio';
import { testimonials } from '../data/testimonials';

const featured = portfolio.filter((p) => p.featured);
const aboutImg = getImage('temple-festival-deity-crown.jpeg');
const stats = [
  { value: '25+', label: 'Years behind the lens' },
  { value: '1000+', label: 'Events & weddings' },
  { value: 'Belvai', label: 'Rooted in our community' },
];
---
<BaseLayout>
  <Hero />

  <!-- About teaser -->
  <section class="bg-cream py-20 sm:py-28">
    <div class="shell grid items-center gap-12 lg:grid-cols-2">
      <Reveal class="order-2 lg:order-1">
        <span class="eyebrow text-maroon">Namaskara from Belvai</span>
        <h2 class="mt-4 font-serif text-4xl text-ink sm:text-5xl">
          A studio that belongs to its people
        </h2>
        <span class="mt-5 block h-px w-16 bg-gold"></span>
        <p class="mt-6 text-lg leading-relaxed text-ink/80">
          Led by {site.owner}, Shobha Digital Studio has been part of life in Belvai and around
          Moodbidri for years — from temple festivals and Yakshagana nights to weddings, naming
          ceremonies and the first portraits of a newborn.
        </p>
        <p class="mt-4 leading-relaxed text-muted">
          We bring a quiet, respectful eye to every occasion, and the craft of a full digital
          studio — photography, cinematography, album design and printing, all under one roof.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href={href('/about')} class="btn btn-primary">Our Story <Icon name="arrow-right" size={16} /></a>
          <a href={href('/services')} class="btn btn-outline">What We Offer</a>
        </div>
      </Reveal>
      <Reveal class="order-1 lg:order-2" delay={120}>
        <div class="relative">
          <div class="overflow-hidden rounded-2xl">
            <Image
              src={aboutImg}
              widths={[480, 800, 1100]}
              sizes="(min-width:1024px) 45vw, 100vw"
              alt="A devotee carrying an ornate deity crown at a temple festival, photographed by Shobha Digital Studio"
              class="h-full w-full object-cover"
            />
          </div>
          <div class="pointer-events-none absolute -bottom-4 -left-4 -z-0 hidden h-24 w-24 rounded-2xl border-2 border-gold/60 sm:block"></div>
        </div>
      </Reveal>
    </div>

    <div class="shell mt-16">
      <div class="grid gap-6 rounded-2xl border border-maroon/10 bg-white/50 p-8 sm:grid-cols-3">
        {stats.map((s) => (
          <div class="text-center">
            <div class="font-serif text-4xl text-maroon">{s.value}</div>
            <div class="mt-1 text-xs font-semibold uppercase tracking-[0.18em] text-muted">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-cream-2 py-20 sm:py-28">
    <div class="shell">
      <Reveal><SectionHeading eyebrow="What we do" title="Services crafted for every occasion" /></Reveal>
      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((service, i) => (
          <Reveal delay={(i % 4) * 80}><ServiceCard service={service} /></Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured work -->
  <section class="bg-cream py-20 sm:py-28">
    <div class="shell">
      <Reveal><SectionHeading eyebrow="Selected work" title="Moments we have framed" /></Reveal>
      <Reveal class="mt-14 block">
        <Gallery items={featured} />
      </Reveal>
      <div class="mt-12 text-center">
        <a href={href('/portfolio')} class="btn btn-primary">View Full Portfolio <Icon name="arrow-right" size={16} /></a>
      </div>
    </div>
  </section>

  <!-- Films -->
  <section class="bg-maroon-dark py-20 sm:py-28">
    <div class="shell">
      <Reveal><SectionHeading eyebrow="On screen" title="Films & cinematography" tone="light" /></Reveal>
      <Reveal class="mt-14 block"><FilmGrid films={films} /></Reveal>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-cream py-20 sm:py-28">
    <div class="shell">
      <Reveal><SectionHeading eyebrow="Kind words" title="What our clients say" /></Reveal>
      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {testimonials.map((item, i) => (
          <Reveal delay={i * 100}><Testimonial item={item} /></Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-maroon py-20">
    <div class="shell text-center">
      <Reveal>
        <p class="font-kannada text-lg text-gold-light">{site.taglineKannada}</p>
        <h2 class="mx-auto mt-4 max-w-2xl font-serif text-4xl text-cream sm:text-5xl">
          Let's capture your story
        </h2>
        <p class="mx-auto mt-5 max-w-xl text-cream/80">
          Planning a wedding, a function or a shoot for your little one? We'd love to hear about it.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn btn-gold">
            <Icon name="whatsapp" size={16} /> Enquire on WhatsApp
          </a>
          <a href={href('/contact')} class="btn btn-ghost-light">Contact Us</a>
        </div>
      </Reveal>
    </div>
  </section>
</BaseLayout>
