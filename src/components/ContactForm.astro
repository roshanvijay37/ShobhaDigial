---
import Icon from './Icon.astro';
import { site, whatsappUrl } from '../data/site';
import { useTranslations, asLang } from '../i18n/utils';

const t = useTranslations(asLang(Astro.currentLocale));
const configured = Boolean(site.web3formsKey);
const fieldClass =
  'w-full rounded-lg border border-maroon/15 bg-cream px-4 py-3 text-sm text-ink placeholder:text-muted/60 focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/30';
---
<form id="enquiry-form" class="space-y-4">
  <input type="hidden" name="access_key" value={site.web3formsKey} />
  <input type="hidden" name="subject" value="New enquiry — Shobha Digital Studio website" />
  <input type="hidden" name="from_name" value="Shobha Digital Studio Website" />
  <!-- Honeypot -->
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.12em] text-maroon" for="name">{t('form.name')} <span aria-hidden="true">*</span></label>
      <input id="name" name="name" type="text" required aria-required="true" placeholder={t('form.namePh')} class={fieldClass} />
    </div>
    <div>
      <label class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.12em] text-maroon" for="phone">{t('form.phone')} <span aria-hidden="true">*</span></label>
      <input id="phone" name="phone" type="tel" required aria-required="true" placeholder="+91 " class={fieldClass} />
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.12em] text-maroon" for="event">{t('form.occasion')}</label>
      <select id="event" name="occasion" class={fieldClass}>
        <option>Wedding</option>
        <option>Pre-Wedding</option>
        <option>Kids / Newborn</option>
        <option>Temple / Ritual</option>
        <option>Yakshagana / Stage</option>
        <option>Portrait / Family</option>
        <option>Event / Function</option>
        <option>Other</option>
      </select>
    </div>
    <div>
      <label class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.12em] text-maroon" for="date">{t('form.date')}</label>
      <input id="date" name="date" type="date" class={fieldClass} />
    </div>
  </div>

  <div>
    <label class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.12em] text-maroon" for="message">{t('form.message')}</label>
    <textarea id="message" name="message" rows="4" placeholder={t('form.messagePh')} class={fieldClass}></textarea>
  </div>

  {!configured && (
    <p class="rounded-lg border border-gold/40 bg-gold/10 px-4 py-3 text-xs text-maroon">
      {t('form.note')}
    </p>
  )}

  <p class="text-xs text-muted">{t('form.required')}</p>

  <div class="flex flex-wrap items-center gap-3">
    <button type="submit" class="btn btn-primary" disabled={!configured}>
      <Icon name="mail" size={16} /> {t('form.send')}
    </button>
    <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn btn-outline">
      <Icon name="whatsapp" size={16} /> {t('form.orWhatsApp')}
    </a>
  </div>

  <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
</form>
