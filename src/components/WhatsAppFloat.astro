---
import Icon from './Icon.astro';
import { whatsappUrl } from '../data/site';
---
<a
  href={whatsappUrl()}
  target="_blank"
  rel="noopener"
  aria-label="Chat with us on WhatsApp"
  class="group fixed bottom-5 right-5 z-40 flex items-center gap-2 rounded-full bg-[#25D366] px-4 py-3 text-white shadow-xl shadow-black/20 transition-transform duration-300 hover:-translate-y-1"
>
  <Icon name="whatsapp" size={24} />
  <span class="hidden text-sm font-semibold sm:inline">WhatsApp</span>
</a>
