---
import type { Testimonial } from '../data/testimonials';
interface Props {
  item: Testimonial;
}
const { item } = Astro.props;
---
<figure class="flex h-full flex-col rounded-xl border border-maroon/10 bg-cream p-8">
  <div class="font-serif text-6xl leading-none text-gold/60" aria-hidden="true">&ldquo;</div>
  <blockquote class="-mt-3 flex-1 text-lg leading-relaxed text-ink/90">{item.quote}</blockquote>
  <figcaption class="mt-6">
    <div class="font-serif text-xl text-maroon">{item.name}</div>
    <div class="mt-1 text-xs uppercase tracking-[0.18em] text-muted">{item.context}</div>
  </figcaption>
</figure>
