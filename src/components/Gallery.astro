---
import { Image, getImage as optimize } from 'astro:assets';
import Icon from './Icon.astro';
import { getImage } from '../lib/images';
import { categoryKn, type PortfolioItem } from '../data/portfolio';
import { asLang } from '../i18n/utils';

interface Props {
  items: PortfolioItem[];
  filters?: string[];
}
const { items, filters } = Astro.props;

// Localize the visible labels; the English category stays the filter key
// (data-filter / data-category) so filtering works identically in both languages.
const kn = asLang(Astro.currentLocale) === 'kn';
const catLabel = (c: string) => (kn ? categoryKn[c] ?? c : c);

// Resolve each photo + a high-res variant for the lightbox (so the fullscreen
// view is crisp instead of a blown-up thumbnail).
const prepared = await Promise.all(
  items.map(async (item) => {
    const meta = getImage(item.file);
    const full = await optimize({
      src: meta,
      width: Math.min(2000, meta.width),
      format: 'webp',
      quality: 82,
    });
    return {
      ...item,
      meta,
      full: full.src,
      titleLoc: kn ? item.titleKn : item.title,
      catLoc: catLabel(item.category),
    };
  }),
);
---
{filters && filters.length > 1 && (
  <div class="mb-10 flex flex-wrap items-center justify-center gap-2.5" role="group" aria-label="Filter gallery">
    {filters.map((cat, i) => (
      <button
        type="button"
        data-filter={cat}
        class:list={[
          'gallery-filter inline-flex min-h-[44px] items-center rounded-full border px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.12em] transition-colors',
          i === 0
            ? 'border-maroon bg-maroon text-cream'
            : 'border-maroon/25 text-maroon hover:border-maroon hover:bg-maroon/5',
        ]}
        aria-pressed={i === 0 ? 'true' : 'false'}
      >
        {catLabel(cat)}
      </button>
    ))}
  </div>
)}

<div id="gallery-grid" data-skew class="gap-4 [column-fill:_balance] sm:columns-2 lg:columns-3">
  {prepared.map((p) => (
    <figure class="gallery-item group mb-4 break-inside-avoid" data-category={p.category}>
      <button
        type="button"
        class="gallery-open relative block w-full overflow-hidden rounded-lg"
        data-img-reveal
        data-webgl
        data-full={p.full}
        data-alt={p.alt}
        data-title={p.titleLoc}
        data-cat={p.catLoc}
        aria-label={p.alt}
      >
        <Image
          src={p.meta}
          widths={[400, 800, 1280]}
          sizes="(min-width:1024px) 33vw, (min-width:640px) 50vw, 100vw"
          alt=""
          loading="lazy"
          class="h-auto w-full transform-gpu transition duration-700 ease-out group-hover:scale-105"
        />
        <span class="pointer-events-none absolute inset-0 flex items-end bg-gradient-to-t from-maroon-dark/70 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100">
          <span class="p-5">
            <span class="block text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-gold-light">{p.catLoc}</span>
            <span class="mt-1 block font-serif text-xl text-cream">{p.titleLoc}</span>
          </span>
        </span>
      </button>
    </figure>
  ))}
</div>

<!-- Lightbox -->
<div
  id="lightbox"
  tabindex="-1"
  class="fixed inset-0 z-[60] hidden items-center justify-center bg-maroon-dark/95 backdrop-blur"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
>
  <button id="lb-close" class="absolute right-3 top-3 inline-flex h-11 w-11 items-center justify-center text-cream/80 hover:text-gold" aria-label="Close image viewer">
    <Icon name="close" size={28} />
  </button>
  <button id="lb-prev" class="absolute left-2 top-1/2 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center text-cream/80 hover:text-gold sm:left-5" aria-label="Previous image">
    <Icon name="chevron-left" size={36} />
  </button>
  <button id="lb-next" class="absolute right-2 top-1/2 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center text-cream/80 hover:text-gold sm:right-5" aria-label="Next image">
    <Icon name="chevron-right" size={36} />
  </button>
  <figure class="flex max-h-[88vh] max-w-[92vw] flex-col items-center gap-3">
    <img id="lb-img" src="" alt="" class="max-h-[80vh] max-w-[92vw] rounded-lg object-contain shadow-2xl" />
    <figcaption class="text-center">
      <span id="lb-cat" class="block text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gold-light"></span>
      <span id="lb-title" class="mt-1 block font-serif text-xl text-cream"></span>
    </figcaption>
  </figure>
</div>
