---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'center' | 'left';
  tone?: 'dark' | 'light';
  class?: string;
}
const { eyebrow, title, align = 'center', tone = 'dark', class: className = '' } = Astro.props;
const titleColor = tone === 'light' ? 'text-cream' : 'text-ink';
const eyebrowColor = tone === 'light' ? 'text-gold-light' : 'text-maroon';
const alignCls = align === 'center' ? 'items-center text-center' : 'items-start text-left';
---
<div class:list={['flex flex-col gap-4', alignCls, className]}>
  {eyebrow && <span class:list={['eyebrow', eyebrowColor]}>{eyebrow}</span>}
  <h2 class:list={['reveal-words max-w-2xl text-4xl font-semibold sm:text-5xl', titleColor]}>{title}</h2>
  {align === 'center' ? (
    <div class="divider w-full max-w-[16rem] text-gold" aria-hidden="true">◆</div>
  ) : (
    <span class="block h-px w-16 bg-gold" aria-hidden="true"></span>
  )}
</div>
