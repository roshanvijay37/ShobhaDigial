---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../SectionHeading.astro';
import Reveal from '../Reveal.astro';
import Icon from '../Icon.astro';
import { whatsappUrl } from '../../data/site';
import { getImage } from '../../lib/images';
import { useTranslations, asLang, navHref } from '../../i18n/utils';

const lang = asLang(Astro.currentLocale);
const t = useTranslations(lang);
const founder = getImage('devanand-bhat.jpeg');

// The family behind the studio — three portraits, no names (client's choice).
// The two studio headshots are exactly 3:4; the son's environmental frame is
// biased low-left so he stays in the crop.
const family = [
  { meta: getImage('devanand-bhat.jpeg'), alt: 'Devanand Bhat, founder of Shobha Digital Studio', pos: 'object-center' },
  { meta: getImage('devanand-wife.jpeg'), alt: 'A member of the family behind Shobha Digital Studio', pos: 'object-center' },
  { meta: getImage('devanand-son.jpeg'), alt: 'A photographer of the team at Shobha Digital Studio, holding a camera', pos: 'object-[32%_78%]' },
];

const values = [
  { icon: 'heart', title: t('about.v1.title'), text: t('about.v1.text') },
  { icon: 'camera', title: t('about.v2.title'), text: t('about.v2.text') },
  { icon: 'sparkles', title: t('about.v3.title'), text: t('about.v3.text') },
  { icon: 'users', title: t('about.v4.title'), text: t('about.v4.text') },
];
---
<BaseLayout
  title="About"
  description="Shobha Digital Studio is a photography and cinematography studio in Belvai, led by Devanand Bhat — rooted in the culture and traditions of coastal Karnataka."
>
  <section class="bg-cream-2 py-16 text-center sm:py-20">
    <div class="shell">
      <p class="font-kannada text-base text-gold">ನಮ್ಮ ಕಥೆ</p>
      <h1 class="mt-3 font-serif text-5xl font-semibold text-ink sm:text-6xl">{t('about.h1')}</h1>
      <div class="divider mx-auto mt-5 max-w-xs text-gold" aria-hidden="true">◆</div>
    </div>
  </section>

  <section class="bg-cream py-16 sm:py-24">
    <div class="shell grid items-center gap-12 lg:grid-cols-2">
      <Reveal>
        <span class="eyebrow text-maroon">{t('about.fromBelvai')}</span>
        <h2 class="mt-4 font-serif text-4xl text-ink sm:text-5xl">{t('about.rootedTitle')}</h2>
        <span class="mt-5 block h-px w-16 bg-gold"></span>
        <p class="mt-6 text-lg leading-relaxed text-ink/80">{t('about.story1')}</p>
        <p class="mt-4 leading-relaxed text-muted">{t('about.story2')}</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href={navHref('/portfolio', lang)} class="btn btn-primary">{t('about.seeWork')} <Icon name="arrow-right" size={16} /></a>
          <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn btn-outline">
            <Icon name="whatsapp" size={16} /> {t('cta.sayHello')}
          </a>
        </div>
      </Reveal>
      <Reveal delay={120}>
        <div class="relative isolate mx-auto w-full max-w-[300px]">
          <div data-tilt="6" class="overflow-hidden rounded-2xl">
            <div data-img-reveal class="overflow-hidden rounded-2xl">
              <Image src={founder} widths={[300, 360]} sizes="300px" alt="Devanand Bhat, founder of Shobha Digital Studio" class="aspect-[3/4] h-full w-full object-cover" />
            </div>
          </div>
          <div class="pointer-events-none absolute -bottom-4 -right-4 -z-10 hidden h-24 w-24 rounded-2xl border-2 border-gold/60 sm:block"></div>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- The family behind the studio (photos only, no names — client's choice) -->
  <section class="bg-cream-2 py-16 sm:py-24">
    <div class="shell">
      <Reveal><SectionHeading eyebrow={t('about.familyEyebrow')} title={t('about.familyTitle')} /></Reveal>
      <div class="mx-auto mt-14 grid max-w-3xl gap-6 sm:grid-cols-3">
        {family.map((member, i) => (
          <Reveal delay={(i % 3) * 90}>
            <div data-tilt="5" class="mx-auto w-full max-w-[260px]">
              <div data-img-reveal class="overflow-hidden rounded-2xl border border-gold/30 shadow-sm shadow-black/5">
                <Image
                  src={member.meta}
                  widths={[260, 360]}
                  sizes="260px"
                  alt={member.alt}
                  class:list={['aspect-[3/4] h-full w-full object-cover', member.pos]}
                />
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-cream py-16 sm:py-24">
    <div class="shell">
      <Reveal><SectionHeading eyebrow={t('about.valuesEyebrow')} title={t('about.valuesTitle')} /></Reveal>
      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {values.map((v, i) => (
          <Reveal delay={(i % 4) * 80}>
            <div data-tilt="5" class="h-full rounded-xl border border-maroon/10 bg-white/50 p-7">
              <div class="grid h-12 w-12 place-items-center rounded-full bg-maroon text-gold">
                <Icon name={v.icon} size={22} />
              </div>
              <h3 class="mt-5 font-serif text-xl text-ink">{v.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{v.text}</p>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-cream-2 py-16">
    <div class="shell text-center">
      <Reveal>
        <h2 class="mx-auto max-w-2xl font-serif text-4xl text-ink sm:text-5xl">{t('about.ctaTitle')}</h2>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn btn-gold">
            <Icon name="whatsapp" size={16} /> {t('cta.enquireWhatsApp')}
          </a>
          <a href={navHref('/contact', lang)} class="btn btn-outline">{t('cta.contactUs')}</a>
        </div>
      </Reveal>
    </div>
  </section>
</BaseLayout>
