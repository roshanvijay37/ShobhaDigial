---
import Icon from './Icon.astro';
import Logo from './Logo.astro';
import { whatsappUrl } from '../data/site';
import { useTranslations, asLang, navHref, localized, altLink } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = asLang(Astro.currentLocale);
const t = useTranslations(lang);
const alt = altLink(Astro.url.pathname, lang);

const nav = [
  { key: 'nav.home' as const, path: '/' },
  { key: 'nav.portfolio' as const, path: '/portfolio' },
  { key: 'nav.services' as const, path: '/services' },
  { key: 'nav.about' as const, path: '/about' },
  { key: 'nav.contact' as const, path: '/contact' },
];

const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
function isActive(path: string) {
  const target = navHref(path, lang).replace(/\/+$/, '') || '/';
  if (path === '/') return current === target;
  return current === target || current.startsWith(target + '/');
}
---
<header class="sticky top-0 z-40 border-b border-gold/40 bg-cream/90 shadow-sm shadow-black/5 backdrop-blur supports-[backdrop-filter]:bg-cream/80">
  <div class="shell flex h-16 items-center justify-between gap-4">
    <a href={localized('/', lang)} class="shrink-0" aria-label="Shobha Digital Studio — home">
      <Logo tone="dark" />
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={navHref(item.path, lang)}
          class:list={[
            'text-sm uppercase tracking-[0.15em] transition-colors',
            isActive(item.path) ? 'text-maroon' : 'text-ink/55 hover:text-maroon',
          ]}
        >
          {t(item.key)}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <a href={alt.href} class="text-sm font-semibold text-ink/65 transition-colors hover:text-maroon" hreflang={alt.lang} aria-label={`Switch language to ${languages[alt.lang]}`}>
        {languages[alt.lang]}
      </a>
      <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn btn-gold">
        <Icon name="whatsapp" size={16} /> {t('cta.enquire')}
      </a>
    </div>

    <div class="flex items-center gap-1 lg:hidden">
      <a
        href={alt.href}
        hreflang={alt.lang}
        lang={alt.lang}
        aria-label={`Switch language to ${languages[alt.lang]}`}
        class="hidden min-h-[44px] items-center rounded-full border border-maroon/25 px-3 text-[0.8rem] font-semibold text-ink transition-colors hover:border-gold hover:text-maroon min-[360px]:inline-flex"
      >
        {languages[alt.lang]}
      </a>
      <button
        id="menu-open"
        class="-mr-2 inline-flex h-11 w-11 items-center justify-center text-ink"
        aria-label="Open menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <Icon name="menu" size={26} />
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    tabindex="-1"
    role="dialog"
    aria-modal="true"
    aria-label="Menu"
    class="fixed inset-0 z-50 hidden bg-cream/98 backdrop-blur lg:hidden"
  >
    <div class="flex h-16 items-center justify-between px-5 sm:px-8">
      <Logo tone="dark" />
      <button id="menu-close" class="-mr-2 inline-flex h-11 w-11 items-center justify-center text-ink" aria-label="Close menu">
        <Icon name="close" size={26} />
      </button>
    </div>
    <nav class="flex flex-col items-center gap-7 pt-14" aria-label="Mobile">
      {nav.map((item) => (
        <a href={navHref(item.path, lang)} class="font-serif text-3xl text-ink transition-colors hover:text-maroon">
          {t(item.key)}
        </a>
      ))}
      <a href={alt.href} hreflang={alt.lang} class="mt-2 rounded-full border border-maroon/30 px-5 py-2 text-sm font-semibold text-ink transition-colors hover:border-gold hover:text-maroon">
        {languages[alt.lang]}
      </a>
      <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn btn-gold mt-2">
        <Icon name="whatsapp" size={16} /> {t('cta.enquireWhatsApp')}
      </a>
    </nav>
  </div>
</header>
