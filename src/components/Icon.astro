---
interface Props {
  name: string;
  class?: string;
  size?: number;
}
const { name, class: className = '', size = 24 } = Astro.props;

// Brand / solid glyphs use fill; the rest are line icons using stroke.
const filled = new Set(['whatsapp', 'facebook', 'play', 'youtube']);

const paths: Record<string, string> = {
