---
import { href } from '../lib/url';
interface Props {
  tone?: 'light' | 'dark';
  class?: string;
}
const { tone = 'dark', class: className = '' } = Astro.props;
const nameColor = tone === 'light' ? 'text-cream' : 'text-maroon';
const subColor = tone === 'light' ? 'text-gold-light' : 'text-gold';
---
<span class:list={['inline-flex items-center gap-3', className]}>
  <img
    src={href('/logo-mark.png')}
    alt=""
    width="40"
    height="44"
    class="h-11 w-auto shrink-0"
    loading="eager"
    decoding="async"
  />
  <span class="leading-none">
    <span class:list={['block whitespace-nowrap font-serif text-base font-semibold tracking-wide sm:text-xl', nameColor]}>
      Shobha Digital Studio
    </span>
    <span class:list={['mt-1 block text-[0.6rem] font-semibold uppercase tracking-[0.42em]', subColor]}>
      Belvai
    </span>
  </span>
</span>
