---
import Icon from './Icon.astro';
interface Props {
  tone?: 'light' | 'dark';
  class?: string;
}
const { tone = 'light', class: className = '' } = Astro.props;
const nameColor = tone === 'light' ? 'text-cream' : 'text-maroon';
const subColor = tone === 'light' ? 'text-gold-light' : 'text-gold';
---
<span class:list={['inline-flex items-center gap-3', className]}>
  <span
    class="grid h-10 w-10 shrink-0 place-items-center rounded-full border border-gold/70 text-gold"
  >
    <Icon name="camera" size={18} />
  </span>
  <span class="leading-none">
    <span class:list={['block font-serif text-lg font-semibold tracking-wide sm:text-xl', nameColor]}>
      Shobha Digital Studio
    </span>
    <span class:list={['mt-1 block text-[0.6rem] font-semibold uppercase tracking-[0.42em]', subColor]}>
      Belvai
    </span>
  </span>
</span>
