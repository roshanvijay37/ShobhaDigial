---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { getImage, hasImage } from '../lib/images';
import type { Film } from '../data/portfolio';
import { useTranslations, asLang } from '../i18n/utils';

interface Props {
  films: Film[];
}
const { films } = Astro.props;
const t = useTranslations(asLang(Astro.currentLocale));
const kn = asLang(Astro.currentLocale) === 'kn';
const prepared = films.map((f) => ({
  ...f,
  poster: f.posterFile && hasImage(f.posterFile) ? getImage(f.posterFile) : null,
  titleLoc: kn ? f.titleKn : f.title,
  catLoc: kn ? f.categoryKn : f.category,
  descLoc: kn ? f.descriptionKn : f.description,
}));
---
<div class="grid gap-6 md:grid-cols-3">
  {prepared.map((film) => {
    const live = Boolean(film.youtubeId);
    const Tag = live ? 'button' : 'div';
    return (
      <article data-tilt="4" class="group overflow-hidden rounded-xl border border-maroon/10 bg-white/60 shadow-sm shadow-maroon/5">
        <Tag
          class:list={['film-open relative block aspect-video w-full overflow-hidden', live && 'cursor-pointer']}
          type={live ? 'button' : undefined}
          data-yt={film.youtubeId}
          data-title={film.titleLoc}
          aria-label={live ? `Play film: ${film.titleLoc}` : undefined}
          aria-disabled={!live ? 'true' : undefined}
        >
          {film.posterUrl ? (
            <img
              src={film.posterUrl}
              alt=""
              loading="lazy"
              class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
            />
          ) : film.poster ? (
            <Image
              src={film.poster}
              widths={[400, 800]}
              sizes="(min-width:768px) 33vw, 100vw"
              alt=""
              loading="lazy"
              class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
            />
          ) : (
            <span class="absolute inset-0 bg-gradient-to-br from-maroon via-maroon-dark to-ink"></span>
          )}
          <span class="absolute inset-0 bg-maroon-dark/40 transition-colors group-hover:bg-maroon-dark/25"></span>
          <span class="absolute inset-0 grid place-items-center">
            {live ? (
              <span class="grid h-16 w-16 place-items-center rounded-full bg-cream/90 text-maroon shadow-lg transition-transform duration-300 group-hover:scale-110">
                <Icon name="play" size={26} />
              </span>
            ) : (
              <span class="rounded-full border border-gold/50 bg-maroon-dark/60 px-4 py-1.5 text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-gold-light">
                {t('films.comingSoon')}
              </span>
            )}
          </span>
        </Tag>
        <div class="p-5">
          <span class="text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-maroon">{film.catLoc}</span>
          <h3 class="mt-1 font-serif text-xl text-ink">{film.titleLoc}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted">{film.descLoc}</p>
        </div>
      </article>
    );
  })}
</div>

<!-- Film lightbox -->
<div
  id="film-lightbox"
  tabindex="-1"
  class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/92 p-4 backdrop-blur"
  role="dialog"
  aria-modal="true"
  aria-label="Film player"
>
  <button id="film-close" class="absolute right-3 top-3 inline-flex h-11 w-11 items-center justify-center text-cream/80 hover:text-gold" aria-label="Close film player">
    <Icon name="close" size={28} />
  </button>
  <div class="aspect-video w-full max-w-4xl overflow-hidden rounded-lg shadow-2xl">
    <iframe
      id="film-frame"
      class="h-full w-full"
      src=""
      title="Film player"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
</div>
