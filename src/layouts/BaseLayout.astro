---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import GrainOverlay from '../components/GrainOverlay.astro';
import { ClientRouter } from 'astro:transitions';
import { site } from '../data/site';
import { href } from '../lib/url';
import { asLang, getHreflangs } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  image?: string; // path under base, or absolute URL
  noindex?: boolean;
}

const {
  title,
  description = 'Shobha Digital Studio, Belvai — wedding, pre-wedding, kids, temple and Yakshagana photography & cinematography across Moodbidri and Dakshina Kannada.',
  image,
  noindex = false,
} = Astro.props;

const lang = asLang(Astro.currentLocale);
const hreflangs = getHreflangs(Astro.url.pathname, Astro.site);
const pageTitle = title ? `${title} · ${site.name}` : `${site.name} · Photography in Belvai`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image ?? href('/og-image.jpg'), Astro.site).href;

const siteUrl = new URL(href('/'), Astro.site).href;
const ogImageAlt = `Photography by ${site.name}, ${site.place}`;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'PhotographyBusiness',
  '@id': siteUrl,
  name: site.name,
  description,
  image: ogImage,
  url: siteUrl,
  telephone: `+${site.phone}`,
  founder: site.owner,
  priceRange: site.priceRange,
  areaServed: 'Dakshina Kannada, Karnataka',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.line1,
    addressLocality: site.address.line1,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: 'IN',
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '09:00',
    closes: '20:00',
  },
  sameAs: [site.social.instagram, site.social.facebook],
};
// Only publish coordinates once the exact studio location is verified.
if (site.geoConfirmed) {
  jsonLd.geo = { '@type': 'GeoCoordinates', latitude: site.geo.lat, longitude: site.geo.lng };
}
if (site.email) jsonLd.email = site.email;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {hreflangs.map((h) => <link rel="alternate" hreflang={h.hreflang} href={h.href} />)}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#fcfbf8" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="2736" />
    <meta property="og:image:height" content="1824" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={href('/favicon.svg')} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Mukta:wght@300;400;500;600;700&family=Noto+Sans+Kannada:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

    <ClientRouter />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-maroon focus:px-4 focus:py-2 focus:text-cream"
    >
      Skip to content
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat />
    <GrainOverlay />

    <script>
      import '../scripts/lifecycle';
    </script>
  </body>
</html>
